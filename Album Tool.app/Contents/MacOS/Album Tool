#!/bin/bash

# Go to the album-tool folder (3 levels up from MacOS/)
DIR="$(cd "$(dirname "$0")/../../../" && pwd)"
cd "$DIR"

# Find Node.js in common install locations
NODE=""
for TRY in \
  /usr/local/bin/node \
  /opt/homebrew/bin/node \
  "$(which node 2>/dev/null)" \
  /opt/homebrew/opt/node/bin/node \
  "$HOME/.nvm/versions/node/$(ls "$HOME/.nvm/versions/node" 2>/dev/null | sort -V | tail -1)/bin/node"
do
  if [ -x "$TRY" ]; then
    NODE="$TRY"
    break
  fi
done

if [ -z "$NODE" ]; then
  osascript -e 'display alert "Node.js not found" message "Please install Node.js 18 or later from nodejs.org, then try again."'
  exit 1
fi

# If already running, just open the browser
if lsof -Pi :3000 -sTCP:LISTEN -t >/dev/null 2>&1; then
  open http://localhost:3000
  exit 0
fi

# Start the server in the background
"$NODE" "$DIR/server.js" &
NODE_PID=$!

# Wait for it to be ready, then open browser
sleep 1.5
open http://localhost:3000

# Keep the .app alive in the Dock — quitting the app stops the server
trap "kill $NODE_PID 2>/dev/null" EXIT
wait $NODE_PID
